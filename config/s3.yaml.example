s3:
  endpoint_url: "https://s3.example.com"
  region: "eu-central-1"
  bucket: "my-bucket"
  prefix: "datasets/ipid-run-001/"

  credentials:
    access_key_id: "${S3_ACCESS_KEY_ID}"
    secret_access_key: "${S3_SECRET_ACCESS_KEY}"

  addressing_style: "path"
  use_ssl: true

upload:
  source_dir: "/data/ipid-run-001/"
  recursive: true
  preserve_directory_structure: true

  include:
    - "**/*.parquet"
    - "**/*.pq"
    - "**/*.json"
    - "**/*.yaml"
    - "**/*.yml"
    - "**/*.csv"
    - "**/*.txt"

  exclude:
    - "**/.DS_Store"
    - "**/tmp/**"
    - "**/*.partial"
    - "**/*.lock"

  multipart:
    enabled: true
    part_size: "512MiB"
    max_concurrent_parts: 16
    max_in_flight_bytes: "8GiB"

    resume: true
    leave_parts_on_error: true

  small_files:
    enabled: true
    multipart_threshold: "64MiB"

  integrity:
    checksum_algorithm: "sha256"
    verify_after_upload: true
    write_manifest: true
    manifest_name: "upload_manifest.json"

  retry:
    max_attempts: 10
    initial_backoff: "1s"
    max_backoff: "60s"
    jitter: true

  performance:
    max_parallel_files: 4
    bandwidth_limit: null
    request_timeout: "120s"
    connect_timeout: "10s"

  overwrite:
    mode: "if_changed"
    compare_by:
      - "size"
      - "mtime"
      - "checksum"

  storage:
    storage_class: "STANDARD"
    content_type_detection: true

logging:
  level: "info"
  progress: true
  progress_interval: "5s"