# --- MANDATORY ---------------------------------------------------------------

# Determine the zmap module used.
# (icmp -> icmp_echoscan, tcp -> tcp_synscan, udp-dns -> udp).
payload: tcp

# Destination port for the scan. Must be null for ICMP and 53 for udp-dns.
port: 80

# Egress interface zmap sends from.
interface:
  name: eth0
  ip: 123.45.67.89

# Stop after this many responsive IP addresses.
# Use null to scan the entire IPv4 space.
# Supports scaled suffixes: K, M, G.
number_of_target_ip_addresses: 100K

# --- RATE --------------------------------------------------------------------

# Bandwidth cap. null disables. Supports scaled suffixes: K, M, G.
bandwidth: 30M

# pps cap. null disables. Supports scaled suffixes: K, M, G.
# packets_per_second: 500K

# --- OPTIONAL ----------------------------------------------------------------

# Seconds zmap keeps listening after the send phase ends.
cooldown_seconds: 8

# Number of zmap send threads. null/0 lets zmap decide (currently 1).
sender_threads: 1

# Probes sent per target.
probes_per_target: 1

# PRNG seed for the IPv4 permutation. null lets zmap generate one.
# seed: 12345

# zmap log verbosity (0=quiet ... 5=trace).
verbosity: 3

# Path to a zmap blacklist file. null lets zmap use default blocklist.
# blacklist_file: /etc/zmap/blocklist.conf

# Path to a zmap whitelist file. Targets are restricted to this set.
# whitelist_file: /etc/zmap/whitelist.conf

# Source port range zmap will use for probes. Both must be set together or
# both null. null lets zmap pick.
# source_port_min: 40000
# source_port_max: 40999

# Test zmap configuration without actually sending any packets
dryrun: false

# Escape hatch for zmap CLI options not modelled above (except output-file).
# Each string is one argument.
# extra_args:
#   - "--max-runtime=3600"
