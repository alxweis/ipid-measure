# --- GENERAL -----------------------------------------------------------------

zmap: tcp-80_2006-01-02_15-04-05

connection_count: 4
requests_per_connection: 4

measurement_mode: rt-based

# --- DETAILS -----------------------------------------------------------------

fixed_interval:
  request_interval: 20ms
  minimum_reply_rate: 0.8

tcp:
  establish_connection: false
  # ELSE
  request_flags: S
  reply_flags:
    - SA
    - RA
    - R

request_ip_ids:
  - 18933
  - 18932
  - 3717
  - 3718
  - 3719

maximum_tolerated_rtt: 2s

# --- SPEED -------------------------------------------------------------------

bandwidth: 30M
packets_per_second: null

# Number of in-flight probes. Needs to be large enough to cover bandwidth * RTT:
# too small wastes bandwidth, too large just wastes a tiny bit of memory.
concurrency: 25K

# --- INTERFACES --------------------------------------------------------------

interfaces:
  a:
    name: eth0
    ip: 123.45.67.89
  b:
    name: eth1
    ip: 123.45.67.90
