# --- GENERAL -----------------------------------------------------------------

zmap: tcp-80_2026-06-03_00-13-06

# Egress interface.
interface:
  name: eth0
  ip: 123.45.67.89

modules:
  ssh: true  # SSH banner
  smb: true  # NTLM Native OS field
  http: true  # HTTP Server header on port 80
  https: true  # HTTP Server header + TLS cert metadata on port 443
  snmp: true  # SNMP sysDescr.0 (in-process UDP probe, no external tool)
  smtp: true  # SMTP banner + EHLO respons

  mssql: true  # Pre-Login response -> Windows
  pop3: true  # POP3 banner
  imap: true  # IMAP banner
  ftp: true  # FTP 220 banner
  telnet: true  # Telnet banner (often router OS)
  dns_chaos: true  # version.bind / hostname.bind CHAOS-class via zdns

# --- SPEED -------------------------------------------------------------------

zgrab2_senders: 1000
zdns_threads: 1000
snmp_workers: 2000

# --- ADDITIONAL --------------------------------------------------------------

connect_timeout: 3s
read_timeout: 3s
snmp_timeout: 2s

snmp_community: public

# zgrab2_binary: /usr/local/bin/zgrab2
# zdns_binary: /usr/local/bin/zdns
